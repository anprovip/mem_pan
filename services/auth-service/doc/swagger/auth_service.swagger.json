      "post": {
        "summary": "Resend verification email",
        "description": "Resend the email verification link",
        "operationId": "AuthService_ResendVerification",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/pbResendVerificationResponse"
